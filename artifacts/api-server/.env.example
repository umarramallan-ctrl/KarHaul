# Copy this file to .env and fill in your values.
# All variables are required in production unless marked optional.

# PostgreSQL connection string
DATABASE_URL=

# Express session secret (random 64+ char string)
SESSION_SECRET=

# Clerk authentication — https://dashboard.clerk.com/last-active?path=api-keys
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=   # optional: only needed for webhook endpoint

# App base URL (used for Stripe Connect redirect URLs)
APP_URL=
