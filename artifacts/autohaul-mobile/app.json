{
  "expo": {
    "name": "KarHaul",
    "slug": "karhaul",
    "version": "1.0.0",
    "owner": "theevopointllc",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "karhaul",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.karhaul.app",
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F172A"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0F172A"
      },
      "splash": {
        "image": "./assets/images/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F172A"
      },
      "package": "com.karhaul.app"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://kar-haul-autohaul.vercel.app"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "apiUrl": "https://karhaul-production.up.railway.app",
      "eas": {
        "projectId": "c9fc7597-d844-4d54-929e-704e8cbf0e25"
      }
    }
  }
}
